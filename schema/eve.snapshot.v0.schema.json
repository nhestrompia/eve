{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eve.local/schema/eve.snapshot.v0.schema.json",
  "title": "EVE Snapshot v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "schemaVersion", "title", "type", "summary", "relationships", "risks", "timeline", "decisions", "validation", "artifacts", "implementation", "createdAt"],
  "properties": {
    "id": { "type": "string" },
    "schemaVersion": { "type": "string", "enum": ["0.1.0", "0.2.0", "0.3.0"] },
    "title": { "type": "string" },
    "type": { "type": "string", "enum": ["feature", "bugfix", "experiment", "refactor", "release"] },
    "summary": { "type": "string" },
    "userVisibleChange": { "type": "string" },
    "relationships": { "$ref": "#/$defs/relationships" },
    "risks": { "type": "array", "items": { "$ref": "#/$defs/risk" } },
    "timeline": { "type": "array", "items": { "$ref": "#/$defs/timeline_entry" } },
    "decisions": { "type": "array", "items": { "$ref": "#/$defs/decision" } },
    "validation": { "type": "array", "items": { "$ref": "#/$defs/validation" } },
    "verification": { "$ref": "#/$defs/verification" },
    "plan": { "$ref": "#/$defs/plan_reference" },
    "planConformance": { "$ref": "#/$defs/plan_conformance" },
    "artifacts": { "type": "array", "items": { "$ref": "#/$defs/artifact" } },
    "implementation": { "$ref": "#/$defs/implementation" },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "relationships": {
      "type": "object",
      "additionalProperties": false,
      "required": ["corrects", "supersedes", "reverts", "dependsOn", "related"],
      "properties": {
        "corrects": { "$ref": "#/$defs/id_list" },
        "supersedes": { "$ref": "#/$defs/id_list" },
        "reverts": { "$ref": "#/$defs/id_list" },
        "dependsOn": { "$ref": "#/$defs/id_list" },
        "related": { "$ref": "#/$defs/id_list" }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "severity"],
      "properties": {
        "title": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "mitigation": { "type": "string" }
      }
    },
    "timeline_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "title"],
      "properties": {
        "phase": { "type": "string", "enum": ["planning", "implementation", "validation", "review", "release"] },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "occurredAt": { "type": "string", "format": "date-time" }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "rationale": { "type": "string" }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "status"],
      "properties": {
        "command": { "type": "string" },
        "status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
        "output": { "type": "string" },
        "provenance": { "type": "string", "enum": ["executed_by_eve", "reported_by_agent", "legacy_unattributed"] }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["not_configured", "not_run", "incomplete", "failed", "required_checks_passed"] },
        "profile": { "type": "string" },
        "suite": { "type": "string" },
        "requiredChecks": { "$ref": "#/$defs/id_list" },
        "ranChecks": { "$ref": "#/$defs/id_list" },
        "checkResults": { "type": "array", "items": { "$ref": "#/$defs/verification_check_result" } },
        "selectedRunId": { "type": "string" },
        "runStartedAt": { "type": "string" },
        "runCompletedAt": { "type": "string" },
        "runRecordDigest": { "type": "string" },
        "configBlobHash": { "type": "string" },
        "executorFingerprint": { "type": "object", "additionalProperties": { "type": "string" } },
        "refContext": { "type": "object" },
        "policyChange": { "$ref": "#/$defs/policy_change" },
        "integrity": { "type": "string" }
      }
    },
    "plan_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision"],
      "properties": {
        "id": { "type": "string" },
        "revision": { "type": "integer", "minimum": 1 }
      }
    },
    "plan_conformance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "noPlanOnFile", "policyMatched", "checkDefinitionsMatch", "scopeDrift", "changedPaths", "outOfScopePaths"],
      "properties": {
        "status": { "type": "string", "enum": ["matched", "failed", "incomplete", "no_plan"] },
        "noPlanOnFile": { "type": "boolean" },
        "requiredChecksStatus": { "type": "string" },
        "policyMatched": { "type": "boolean" },
        "checkDefinitionsMatch": { "type": "boolean" },
        "scopeDrift": { "type": "boolean" },
        "changedPaths": { "$ref": "#/$defs/id_list" },
        "outOfScopePaths": { "$ref": "#/$defs/id_list" }
      }
    },
    "policy_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changed", "requirementsReduced"],
      "properties": {
        "changed": { "type": "boolean" },
        "requirementsReduced": { "type": "boolean" },
        "policyIntroduced": { "type": "boolean" },
        "profileIntroduced": { "type": "boolean" },
        "profileRemoved": { "type": "boolean" },
        "previousConfigHash": { "type": "string" },
        "currentConfigHash": { "type": "string" },
        "addedChecks": { "$ref": "#/$defs/id_list" },
        "removedChecks": { "$ref": "#/$defs/id_list" }
      }
    },
    "verification_check_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkId", "status"],
      "properties": {
        "checkId": { "type": "string" },
        "status": { "type": "string" },
        "exitCode": { "type": "integer" },
        "startedAt": { "type": "string" },
        "completedAt": { "type": "string" },
        "output": { "type": "string" },
        "outputBytes": { "type": "integer" },
        "outputDigest": { "type": "string" },
        "truncated": { "type": "boolean" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["screenshot", "video", "preview", "url", "note", "log", "conversation"] },
        "uri": { "type": "string" },
        "path": { "type": "string" },
        "url": { "type": "string" },
        "mimeType": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch", "gitState", "commits", "dirty"],
      "properties": {
        "branch": { "type": "string" },
        "gitState": { "type": "string" },
        "baseCommit": { "type": "string" },
        "commits": { "$ref": "#/$defs/id_list" },
        "dirty": { "type": "boolean" }
      }
    },
    "id_list": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
