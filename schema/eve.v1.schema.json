{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eve.local/schema/eve.v1.schema.json",
  "title": "EVE Evolution v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eve",
    "metadata",
    "intent",
    "outcome",
    "behavior",
    "decisions",
    "risks",
    "verification",
    "sessions",
    "timeline",
    "relationships",
    "implementation",
    "extensions"
  ],
  "properties": {
    "eve": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version"],
      "properties": {
        "version": {
          "const": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "description": "Recommended values: feature, bugfix, refactor, migration, security, performance, maintenance, documentation, infrastructure. Producers may define additional types."
        },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "completed", "archived"]
        },
        "created_by": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "intent": {
      "type": "string"
    },
    "outcome": {
      "type": "string"
    },
    "behavior": {
      "$ref": "#/$defs/behavior"
    },
    "decisions": {
      "type": "array"
    },
    "risks": {
      "type": "array"
    },
    "verification": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verification"
      }
    },
    "sessions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/session"
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/timeline_entry"
      }
    },
    "relationships": {
      "$ref": "#/$defs/relationships"
    },
    "implementation": {
      "$ref": "#/$defs/implementation"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "behavior": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "added": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/behavior_claim"
          }
        },
        "changed": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/behavior_claim"
          }
        },
        "removed": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/behavior_claim"
          }
        },
        "fixed": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/behavior_claim"
          }
        }
      }
    },
    "behavior_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commits": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "type": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "skipped", "pending", "generated", "approved"]
        },
        "reference": {
          "type": "string"
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      }
    },
    "timeline_entry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "actor": {
          "$ref": "#/$defs/actor"
        },
        "event": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "id": {
          "type": "string"
        }
      }
    },
    "relationships": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "extends": {
          "$ref": "#/$defs/id_list"
        },
        "depends_on": {
          "$ref": "#/$defs/id_list"
        },
        "corrects": {
          "$ref": "#/$defs/id_list"
        },
        "supersedes": {
          "$ref": "#/$defs/id_list"
        },
        "reverts": {
          "$ref": "#/$defs/id_list"
        },
        "related": {
          "$ref": "#/$defs/id_list"
        }
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repositories": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/repository"
          }
        },
        "snapshot": {
          "type": "string",
          "description": "Resolved Git commit SHA representing the repository state after this Evolution became true."
        },
        "commits": {
          "$ref": "#/$defs/id_list"
        },
        "pull_requests": {
          "$ref": "#/$defs/id_list"
        },
        "files_changed": {
          "type": "integer",
          "minimum": 0
        },
        "insertions": {
          "type": "integer",
          "minimum": 0
        },
        "deletions": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string"
        }
      }
    },
    "id_list": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
